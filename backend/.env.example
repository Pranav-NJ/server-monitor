# ── Environment ───────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true

# ── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=server_monitor

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-supersecretkey-256bit
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Twilio (mock values for development) ─────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15551234567
SMS_RECIPIENT_NUMBER=+1234567890

# ── SendGrid (email alerts) ──────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=
EMAIL_RECIPIENT=

# ── Alert Poller ─────────────────────────────────────────
ALERT_POLL_INTERVAL_SECONDS=30
